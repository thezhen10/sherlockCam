{
  "name": "sherlock-cam",
  "version": "0.1.0",
  "description": "Framework-agnostic camera scanning engine (OCR + barcode) with a pluggable detector architecture. Detects targeted content, pauses, and waits for dismissal before resuming - designed to be embedded as a component in a larger app or game.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "tsup",
    "build:demo": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "tesseract.js": "^7.0.0",
    "zxing-wasm": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
